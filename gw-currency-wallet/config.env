HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_ACCESS_LOG=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wallet
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_API_MAX_OPEN_CONNS=10
POSTGRES_WORKER_MAX_OPEN_CONNS=10

JWT_SECRET=local-dev-secret
JWT_TOKEN_TTL_MINUTES=60

EXCHANGER_GRPC_HOST=localhost
EXCHANGER_GRPC_PORT=50051
EXCHANGER_GRPC_REQUEST_TIMEOUT_MS=3000

WORKER_POLL_INTERVAL_MS=1000
WORKER_WALLETS_LIMIT=128
WORKER_BATCH_SIZE=128
WORKER_CONCURRENCY=2

LOG_LEVEL=debug
